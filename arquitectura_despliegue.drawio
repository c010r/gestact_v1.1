<mxfile host="app.diagrams.net">
  <diagram id="arquitectura-despliegue" name="Despliegue ASSE-GestIT">
    <mxGraphModel dx="1120" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="zonaClientes" value="Zona Clientes" style="swimlane;fontStyle=1;childLayout=stackLayout;horizontal=1;startSize=24;horizontalStack=0;resizeLast=0;swimlaneFillColor=#f5f5f5;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="230" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="clientes" value="Usuarios Web&#xa;- Soporte&#xa;- Administrativos" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="zonaClientes">
          <mxGeometry x="40" y="50" width="150" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="zonaPerimetro" value="Zona Perimetral / DMZ" style="swimlane;fontStyle=1;horizontal=1;startSize=24;swimlaneFillColor=#f8f8f8;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="310" y="40" width="320" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="internet" value="Internet / VPN" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontStyle=2;fontSize=13;" vertex="1" parent="zonaPerimetro">
          <mxGeometry x="20" y="30" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="proxy" value="Balanceador / Proxy Reverso&#xa;- Nginx / Traefik&#xa;- Certificados TLS&#xa;- Gzip + Brotli" style="shape=process;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="zonaPerimetro">
          <mxGeometry x="170" y="30" width="130" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="cdn" value="Entrega de Est&#225;ticos&#xa;- React build &#xa;- CSS/JS/Assets" style="shape=process;whiteSpace=wrap;html=1;rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="zonaPerimetro">
          <mxGeometry x="20" y="130" width="130" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="zonaAplicacion" value="Zona de Aplicaci&#243;n" style="swimlane;fontStyle=1;horizontal=1;startSize=24;swimlaneFillColor=#fdf4e3;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="660" y="40" width="380" height="360" as="geometry"/>
        </mxCell>
        <mxCell id="frontend" value="Contenedor Frontend&#xa;- React + Vite build&#xa;- Servido por Nginx&#xa;- `.env` apuntando a API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="zonaAplicacion">
          <mxGeometry x="30" y="30" width="150" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="backend" value="Contenedor Backend&#xa;- Django + DRF + Gunicorn&#xa;- Endpoints `/api/*`&#xa;- Manejo de plantillas y tareas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="zonaAplicacion">
          <mxGeometry x="210" y="30" width="170" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="media" value="Almacenamiento de Media&#xa;- Sistema de archivos compartido&#xa;- Respaldos diarios&#xa;- Archivos adjuntos / reportes" style="shape=process;whiteSpace=wrap;html=1;rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="zonaAplicacion">
          <mxGeometry x="30" y="190" width="150" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="servicios" value="Servicios Externos&#xa;- SMTP / Notificaciones&#xa;- Autenticaci&#243;n corporativa&#xa;- Integraciones REST" style="shape=process;whiteSpace=wrap;html=1;rounded=1;fillColor=#dbeaff;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="zonaAplicacion">
          <mxGeometry x="210" y="200" width="170" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="zonaDatos" value="Zona de Datos" style="swimlane;fontStyle=1;horizontal=1;startSize=24;swimlaneFillColor=#f0e6ff;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="420" y="320" width="230" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="bd" value="Servidor BD&#xa;- PostgreSQL / MySQL / Oracle&#xa;- Migraciones Django&#xa;- Backups autom&#225;ticos" style="cylinder;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="zonaDatos">
          <mxGeometry x="50" y="40" width="140" height="120" as="geometry"/>
        </mxCell>

        <!-- conexiones -->
        <mxCell id="edge1" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="clientes" target="internet"/>
        <mxCell id="edge2" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="internet" target="proxy"/>
        <mxCell id="edge3" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="internet" target="cdn"/>
        <mxCell id="edge4" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82b366" edge="1" parent="1" source="proxy" target="frontend"/>
        <mxCell id="edge5" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#b85450" edge="1" parent="1" source="proxy" target="backend"/>
        <mxCell id="edge6" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673a6" edge="1" parent="1" source="backend" target="bd"/>
        <mxCell id="edge7" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#d6b656" edge="1" parent="1" source="backend" target="media"/>
        <mxCell id="edge8" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#d6b656" edge="1" parent="1" source="servicios" target="backend"/>
        <mxCell id="edge9" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673a6" edge="1" parent="1" source="frontend" target="cdn"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
