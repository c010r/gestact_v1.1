<mxfile host="app.diagrams.net">
  <diagram id="arquitectura-reducida" name="Arquitectura Reducida">
    <mxGraphModel dx="1080" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="start" value="Usuarios / Navegadores&#xa;- T&#233;cnicos&#xa;- Administrativos" style="shape=terminator;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="request" value="Solicitud HTTP&#xa;(GET / POST)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="45" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="Capa de Presentaci&#243;n&#xa;- Templates Django&#xa;- Bootstrap + JS&#xa;- Widgets (TreeSelect, Charts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="540" y="20" width="260" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="views" value="Capa de Aplicaci&#243;n&#xa;- CBVs (List, Detail, Create)&#xa;- Formularios y validaciones&#xa;- DRF ViewSets + Serializers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="540" y="160" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="business" value="Capa de Negocio&#xa;- Models + reglas&#xa;- Bit&#225;cora y signals&#xa;- Servicios de inventario / facturaci&#243;n" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="data" value="Capa de Datos&#xa;- Django ORM&#xa;- SQLite (dev)&#xa;- PostgreSQL / MySQL / Oracle (prod)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="540" y="480" width="260" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="response" value="Respuesta HTML / JSON&#xa;- Tablas y dashboards&#xa;- Reportes y remitos" style="shape=terminator;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="540" y="640" width="260" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="apis" value="APIs REST / Integraciones&#xa;- CRUD de activos&#xa;- Servicios externos&#xa;- Notificaciones / tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="860" y="250" width="260" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="edge1" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="start" target="request"/>
        <mxCell id="edge2" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="request" target="frontend"/>
        <mxCell id="edge3" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#82b366" edge="1" parent="1" source="frontend" target="views"/>
        <mxCell id="edge4" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#d79b00" edge="1" parent="1" source="views" target="business"/>
        <mxCell id="edge5" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#b85450" edge="1" parent="1" source="business" target="data"/>
        <mxCell id="edge6" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673a6" edge="1" parent="1" source="data" target="response"/>
        <mxCell id="edge7" style="endArrow=block;endFill=1;strokeWidth=2;strokeColor=#9673a6" edge="1" parent="1" source="response" target="start">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="190" y="640" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="edge8" style="endArrow=block;endFill=1;strokeWidth=2;dashed=1;strokeColor=#d6b656" edge="1" parent="1" source="views" target="apis"/>
        <mxCell id="edge9" style="endArrow=block;endFill=1;strokeWidth=2;dashed=1;strokeColor=#d6b656" edge="1" parent="1" source="apis" target="business"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
